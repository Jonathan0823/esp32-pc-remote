{
  "project": {
    "name": "PC Remote Control Panel",
    "goal": "Recreate the provided desktop and mobile layout exactly while using native shadcn/ui styling.",
    "sourceReference": "Black and white desktop + mobile PC Remote control panel mockup from the current conversation.",
    "implementationPriority": [
      "Match layout, spacing, proportions, content hierarchy, and responsive behavior.",
      "Use shadcn/ui components without visually restyling them.",
      "Only customize dimensions, spacing, grid placement, responsive breakpoints, and content.",
      "Do not recreate the mockup using custom visual CSS."
    ]
  },
  "criticalInstructions": {
    "mustUseShadcnDefaults": true,
    "doNotOverride": [
      "shadcn color tokens",
      "shadcn border colors",
      "shadcn border radius",
      "shadcn shadows",
      "shadcn button variants",
      "shadcn card appearance",
      "shadcn badge appearance",
      "shadcn typography colors",
      "shadcn hover states",
      "shadcn focus rings",
      "shadcn dark theme variables"
    ],
    "allowedOverrides": [
      "width",
      "height",
      "min-width",
      "max-width",
      "grid-template-columns",
      "grid-column",
      "grid-row",
      "gap",
      "padding",
      "margin",
      "alignment",
      "display",
      "position",
      "overflow",
      "responsive visibility",
      "responsive ordering"
    ],
    "forbiddenCustomStyling": [
      "custom gradients",
      "custom glows",
      "custom glassmorphism",
      "custom card backgrounds",
      "custom button colors",
      "custom badge colors",
      "custom shadows",
      "custom border colors",
      "custom radius values",
      "decorative neon effects",
      "illustration-heavy graphics"
    ],
    "theme": {
      "system": "shadcn/ui",
      "mode": "dark",
      "palette": "default neutral black-white shadcn theme",
      "cssRule": "Use the generated shadcn CSS variables from globals.css exactly as installed.",
      "componentRule": "Prefer component variants over custom class-based visual styling."
    }
  },
  "stack": {
    "framework": "React",
    "recommended": "Next.js or Vite",
    "styling": "Tailwind CSS",
    "componentLibrary": "shadcn/ui",
    "icons": "lucide-react",
    "mqtt": "mqtt.js over WSS",
    "responsiveStrategy": "desktop-first exact layout with mobile single-column adaptation"
  },
  "shadcnComponents": {
    "required": [
      "Sidebar",
      "SidebarProvider",
      "SidebarHeader",
      "SidebarContent",
      "SidebarFooter",
      "SidebarMenu",
      "SidebarMenuItem",
      "SidebarMenuButton",
      "Card",
      "CardHeader",
      "CardTitle",
      "CardDescription",
      "CardContent",
      "Button",
      "Badge",
      "Separator",
      "Progress",
      "Dialog",
      "DialogContent",
      "DialogHeader",
      "DialogTitle",
      "DialogDescription",
      "DialogFooter",
      "Sheet",
      "SheetContent",
      "DropdownMenu",
      "DropdownMenuTrigger",
      "DropdownMenuContent",
      "DropdownMenuItem",
      "ScrollArea",
      "Tooltip"
    ],
    "usageRule": "Do not copy shadcn internals or manually reproduce component visuals. Import and compose the official generated components."
  },
