  "responsive": {
    "desktop": {
      "minWidth": 1180,
      "sidebar": "expanded",
      "dashboardGrid": "2 columns x 2 rows"
    },
    "tablet": {
      "range": "768px to 1179px",
      "sidebar": "collapsed icon mode",
      "dashboardGrid": "2 columns where possible",
      "fallback": "single column if content becomes cramped"
    },
    "mobile": {
      "maxWidth": 767,
      "sidebar": "hidden",
      "headerMenu": "Sheet",
      "dashboardGrid": "single column",
      "bottomNavigation": "fixed"
    }
  },
  "interactions": {
    "wake": {
      "trigger": "WAKE PC button",
      "component": "Dialog",
      "flow": [
        {
          "state": "initial",
          "title": "Wake Desktop PC?",
          "description": "Request confirmation from the ESP32 before sending the Wake-on-LAN packet.",
          "actions": [
            {
              "label": "Cancel",
              "variant": "outline"
            },
            {
              "label": "Continue",
              "variant": "default",
              "action": "publish wake_request"
            }
          ]
        },
        {
          "state": "waiting",
          "title": "Waiting for controller",
          "description": "Requesting a temporary confirmation token from Desktop-01."
        },
        {
          "state": "confirm",
          "title": "Confirm wake",
          "description": "The request expires in {{secondsLeft}} seconds.",
          "actions": [
            {
              "label": "Cancel",
              "variant": "outline"
            },
            {
              "label": "Wake PC",
              "variant": "default",
              "action": "publish wake_confirm"
            }
          ]
        },
        {
          "state": "success",
          "title": "Wake packet sent",
          "description": "Desktop-01 sent the Wake-on-LAN packet."
        }
      ]
    },
    "ping": {
      "trigger": "PING button",
      "feedback": "Use shadcn Sonner toast with latency result."
    },
    "reboot": {
      "trigger": "REBOOT button",
      "component": "AlertDialog",
      "title": "Reboot ESP32?",
      "description": "The controller will disconnect briefly and reconnect automatically."
    }
  },
  "agentChecklist": [
    "Install shadcn/ui using the official CLI.",
    "Select the standard dark neutral theme.",
    "Do not add custom visual tokens.",
    "Do not override component classes for color, radius, border, or shadow.",
    "Use layout utility classes only for exact spacing and placement.",
    "Use Card for all dashboard panels.",
    "Use Button variants default, outline, ghost, and destructive only.",
    "Use Badge variant secondary for labels and event tags.",
    "Use Separator between list rows.",
    "Use Progress only for signal quality.",
    "Use Sidebar on desktop and Sheet on mobile.",
    "Match the desktop 244px sidebar and 2x2 dashboard grid.",
    "Match the mobile card order and fixed bottom navigation.",
    "Use lucide-react icons only.",
    "Avoid custom illustrations; use the Monitor icon for the PC visual.",
    "Keep content and labels exactly as specified."
  ]
}
